          }

          var infowindow = new google.maps.InfoWindow({
            content: 'contentString'
          });

          infoBubles[infoBubles.length] = infowindow;
        }
        total_meter += parseFloat(data.root[i].meter);
        last_engine = engine;
        last_angle = parseFloat(data.root[i].angle);        
        bounds.extend(pt);
        path.push(pt);
      }

      var strokeColor = map.getMapTypeId() == 'NAVIGASI' ? '#CC33FF' : "#FF0000";

