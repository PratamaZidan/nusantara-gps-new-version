    function NewMarkerClass() {
        function NewMarker(position, icon = 'icon.png', onoff = 0) {
            var frame = document.location.origin+"/assets/icon/"+ (parseInt( onoff ) === 1 ? 'background-green.png' : 'background-red.png');
            
            this.position = position;
            this.icon = icon;
            this.frame = frame;

            this.containerDiv = document.createElement('div');
            this.containerDiv.classList.add('new-marker-container');
            this.containerDiv.innerHTML =
                '<div class="new-marker-bubble-anchor">'+
                    '<div class="new-marker-bubble-icon">'+
                        '<img src="'+ this.icon +'">'+
                    '</div>'+
                    '<div class="new-marker-bubble">'+
                        '<img src="'+ this.frame +'">'+
                    '</div>'+
                '</div>';

            google.maps.OverlayView.preventMapHitsAndGesturesFrom(this.containerDiv);
        }

        NewMarker.prototype = Object.create(google.maps.OverlayView.prototype);
        NewMarker.prototype.onAdd = function() {
            this.getPanes().floatPane.appendChild(this.containerDiv);

            var me = this;

            google.maps.event.addDomListener(this.containerDiv, 'click', function(e) {
                google.maps.event.trigger(me, 'click', me, e);
            });
        };

        NewMarker.prototype.onRemove = function() {
            if (this.containerDiv.parentElement) {
                this.containerDiv.parentElement.removeChild(this.containerDiv);
            }
        };

        NewMarker.prototype.draw = function() {
            var divPosition = this.getProjection().fromLatLngToDivPixel(this.position);
            var display = Math.abs(divPosition.x) < 4000 && Math.abs(divPosition.y) < 4000
                ? 'block'
                : 'none';

            if (display === 'block') {
                this.containerDiv.style.left = divPosition.x + 'px';
                this.containerDiv.style.top = divPosition.y + 'px';
            }
            if (this.containerDiv.style.display !== display) {
                this.containerDiv.style.display = display;
            }
        };
        
        NewMarker.prototype.setPosition = function(position) {
            this.position = position;
        };
        
        NewMarker.prototype.setIcon = function(icon) {
            this.icon = icon;
        };
        
        NewMarker.prototype.setTitle = function(title) {
            this.title = title;
        };
        
        NewMarker.prototype.setEngine = function(engine) {
            var frame = document.location.origin+"/assets/icon/"+ (parseInt( engine ) === 1 ? 'background-green.png' : 'background-red.png');
            this.frame = frame;
        };

        return NewMarker;
    }

});


