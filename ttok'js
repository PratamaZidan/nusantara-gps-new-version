          '</tr>';
          table.append(markup);
          savedHistoryArray.push(value);
        });


          pageSize = 3;
          pagesCount = $('.shistory').length;
          //pages = pagesCount / 2;
          var currentPage = 1;
    
          /////////// PREPARE NAV ///////////////
          var nav = '';
          var totalPages = Math.ceil(pagesCount / pageSize);
          console.log("tp :", pagesCount);
          for (var s=0; s<totalPages; s++){
              nav += '<li class="num"><a href="#">'+(s+1)+'</a></li>';
          }
          $(".prev").after(nav);
          $(".num").first().addClass("active");
          //////////////////////////////////////

          showPage = function() {
            $(".shistory").hide().each(function(n) {
            if (n >= pageSize * (currentPage - 1) && n < pageSize * currentPage)
                $(this).show();
            });
          }
          showPage();


          $(".pagination li.num").click(function() {
          $(".pagination li").removeClass("active");
          $(this).addClass("active");
            currentPage = parseInt($(this).text());
          showPage();
          });

          $(".pagination li.prev").click(function() {
            if($(this).next().is('.active')) return;
          $('.num.active').removeClass('active').prev().addClass('active');
              currentPage = currentPage > 1 ? (currentPage-1) : 1;
          showPage();
          });

          $(".pagination li.next").click(function() {
              if($(this).prev().is('.active')) return;
          $('.num.active').removeClass('active').next().addClass('active');
              currentPage = currentPage < totalPages ? (currentPage+1) : totalPages;
          showPage();
          });


      }
    })

    console.log('refreshing saved history');
  }


