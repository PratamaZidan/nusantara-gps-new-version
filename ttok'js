      success: function(data) {
        $.each(data['root'], function( index, value ) {
          var markup = '<tr class="shistory">'+
          '<td>'+ value.nama +'</td>'+
          '<td><i class="fa fa-eye marright2"></i> <a href="#" class="displaySavedHistory" data-index="'+index+'">Lihat</a></td>'+
