            mark1.setMap(map);
            google.maps.event.addListener(mark1, 'click', function () {
                iw1.open(map, mark1);
            });
            historyMarkers.push(mark1);
        }

        var bounds = new google.maps.LatLngBounds();
        var path = new Array();
        var titles = new Array();

        var engine = '0', last_engine = '', total_meter = 0, last_angle = -1, angle_diff=0;
        
        for(var i=0,len=data.root.length; i<len; i++) {
            var pt = new google.maps.LatLng(data.root[i].lat, data.root[i].lng);
            historyLine.push(data.root[i]);
        //engine = data.device_type == 'spring' && typeof data.root[i]['tmp2'] != 'undefined' && data.root[i].tmp2.length >= 3 ? data.root[i].tmp2.charAt(2) : '0';
        //angle_diff = last_angle >= 0 ? Math.abs( parseFloat(data.root[i].angle) - last_angle ) : 0;
        if (total_meter > 10000)  {
          var txt = data.root[i].time_stamp;
