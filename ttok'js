function goPlaymob() {
    if (!isplay) return;
    if (typeof historyLine[historyLinePos] == 'undefined') {
      playHistorymob();
      return;
    }

    if (historyLinePos > 0) {infowindowHistory.close();}
    console.log('memainkan');
    console.log('line pos', historyLine[historyLinePos]);
    var devid = $("#deviceselector2mob").val();
    var marker = MARKERS[devid];
    historyLinePos++;

    var infowindowContent = historyLine[historyLinePos].title;
    if (infowindowContent === null) {
      isplay = false;
    }
    infowindowHistory = new google.maps.InfoWindow({
      content: 'Posisi : ' + infowindowContent
    });

    if (window.console) console.log([ 'marker:', marker, devid  ]);
    google.maps.event.clearListeners(marker, 'click');

    var angels = historyLine[historyLinePos].angle;
    
    if (angels >= 0 && angels <= 14){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil1.png"); 

    }else if(angels >= 15 && angels <= 75 ){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil2.png"); 

    }else if(angels >= 76  &&  angels <= 104){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil3.png"); 

    }else if(angels >= 105 && angels <= 165){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil4.png"); 

    }else if(angels >= 166 && angels <= 194){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil5.png"); 

    }else if(angels >= 195 && angels <= 255){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil6.png");

    }else if(angels >= 256 && angels <= 284){

       var  icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil7.png"); 

    }else if(angels >= 285 && angels <= 345){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil8.png");

    }else if (angels >= 346 && angels <= 360){

       var icons = new google.maps.MarkerImage(document.location.origin + "/assets/icon/mobil1_off.png"); 

    } 

    var pointz = new google.maps.LatLng( historyLine[historyLinePos].lat, historyLine[historyLinePos].lng );

    infowindowHistory.setPosition( pointz );
    marker.setPosition( pointz );
    marker.setMap( map );
    marker.setIcon( icons );
    map.panTo( new google.maps.LatLng( historyLine[historyLinePos].lat, historyLine[historyLinePos].lng  ) );
    infowindowHistory.open(map, marker);
}

