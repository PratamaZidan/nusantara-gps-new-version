function showGeofence( data, isedit ) {
    var allBound = new google.maps.LatLngBounds();

    switch ( data.geo_type ) {
        case '1' :
            var overlayOption = drawingManager.circleOptions;
            overlayOption.clickable = isedit;
            overlayOption.editable = isedit;
            overlayOption.center = new google.maps.LatLng( data.geo_point1, data.geo_point2 );
            overlayOption.radius = parseInt( data.geo_point3 );

            var overlay = new google.maps.Circle( overlayOption ),
                o = {type:'circle', overlay: overlay};

            overlay.setMap( map );
            allBound.extend( overlay.getBounds().getNorthEast() );
            allBound.extend( overlay.getBounds().getSouthWest() );

            if ( isedit ) {
                google.maps.event.addListener(overlay, 'radius_changed', function() { updateOverlay( o ); });
                google.maps.event.addListener(overlay, 'center_changed', function() { updateOverlay( o ); });
            }

            $('#geo_point_geofence').val( data.geo_point1 +','+ data.geo_point2 +','+ data.geo_point3 );

            break;

        case '2' :
            var bounds = new google.maps.LatLngBounds();

            bounds.extend(new google.maps.LatLng( data.geo_point1, data.geo_point2 ));
            bounds.extend(new google.maps.LatLng( data.geo_point3, data.geo_point4 ));

            allBound.extend(new google.maps.LatLng( data.geo_point1, data.geo_point2 ));
            allBound.extend(new google.maps.LatLng( data.geo_point3, data.geo_point4 ));

            var overlayOption = drawingManager.rectangleOptions;
            overlayOption.clickable = isedit;
            overlayOption.editable = isedit;
            overlayOption.bounds = bounds;

            var overlay = new google.maps.Rectangle( overlayOption ),
                o = {type:'rectangle', overlay: overlay};

            overlay.setMap( map );

            if ( isedit ) {
                google.maps.event.addListener(overlay, 'bounds_changed', function() { updateOverlay( o ); });
            }

            $('#geo_point_geofence').val( data.geo_point1 +','+ data.geo_point2 +','+ data.geo_point3 +','+ data.geo_point4 );

            break;

        default :
            var points = data.polygon.split('|'), l;

            if ( l = points.length ) {
                var paths = [];
                for (var i=0;i<l;i++ ) {
                    var point = points[i].split(',');

                    if ( point.length != 2 ) continue;
                    paths.push(new google.maps.LatLng( point[0], point[1] ));
                    allBound.extend(new google.maps.LatLng( point[0], point[1] ));
                }

                var overlayOption = drawingManager.polygonOptions;
                overlayOption.clickable = isedit;
                overlayOption.editable = isedit;
                overlayOption.paths = paths;

                var overlay = new google.maps.Polygon( overlayOption ),
                    o = {type:'polygon', overlay: overlay};

                overlay.setMap( map );

                if ( isedit ) {
                    google.maps.event.addListener(overlay, 'mouseup', function() { updateOverlay( o ); });
                }
            }

            $('#geo_point_geofence').val( data.polygon );
        }

        overlayArray.push( overlay );
        map.fitBounds( allBound );
    }

  function updateOverlay( overlay ) {
      var geo_type = '',
      geo_point = '';

      switch (overlay.type) {
        case "circle":
        geo_type = '1';
        geo_point = overlay.overlay.getCenter().lat() + ',' + overlay.overlay.getCenter().lng() + ',' + overlay.overlay.getRadius();
        break;
        case "rectangle":
        geo_type = '2';
        geo_point = overlay.overlay.getBounds().getSouthWest().lat() + ',' + overlay.overlay.getBounds().getNorthEast().lng() + ',' + overlay.overlay.getBounds().getNorthEast().lat() + ',' + overlay.overlay.getBounds().getSouthWest().lng();
        break;
        case "polygon":
        var i, p, o = overlay.overlay,
        l = overlay.overlay.getPath().getLength();
        geo_type = '0';
        geo_point = []
        for (i = 0; i < l; i++) {
          p = o.getPath().getAt(i);
          geo_point.push(p.toUrlValue(6));
        }
        if (geo_point.length) {
          geo_point = geo_point.join('|');
        }
        break;
      }
      $('#geo_type_geofence').val( geo_type );
      $('#geo_point_geofence').val( geo_point );
    }

